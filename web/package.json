{
  "name": "web",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "gen:types": "cd .. && python api/scripts/export_openapi.py --out web/.openapi.json && cd web && openapi-typescript .openapi.json -o src/lib/api-types.ts && rm .openapi.json",
    "verify:types": "cd .. && python api/scripts/export_openapi.py --out web/.openapi.json && cd web && openapi-typescript .openapi.json -o /tmp/api-types.generated.ts && diff -u src/lib/api-types.ts /tmp/api-types.generated.ts && rm .openapi.json /tmp/api-types.generated.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "qa": "npx playwright test --config=playwright.config.ts",
    "qa:chromium": "npx playwright test --config=playwright.config.ts --project='chromium-*'",
    "qa:firefox": "npx playwright test --config=playwright.config.ts --project='firefox-*'",
    "qa:webkit": "npx playwright test --config=playwright.config.ts --project='webkit-*'",
    "qa:mobile": "npx playwright test --config=playwright.config.ts --project='*-mobile-*'",
    "qa:desktop": "npx playwright test --config=playwright.config.ts --project='*-desktop-*'",
    "qa:pwa": "npx playwright test --config=playwright.config.ts --project='pwa-*'",
    "qa:report": "npx playwright show-report qa-output/playwright-report"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/typography": "^0.5.20",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.2",
    "konva": "^10.3.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.78.0",
    "react-konva": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "@babel/core": ">=7.29.6",
    "js-yaml": ">=4.2.0"
  }
}
