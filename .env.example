# Tendril Environment Configuration
# Copy this to .env and customize for your deployment
# Generate JWT_SECRET: openssl rand -hex 32

# ─────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────

# Authentication secret — MUST be unique and strong
JWT_SECRET=your-random-64-character-secret-here

# Your domain — used for CORS and email links
DOMAIN=localhost
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────

# PostgreSQL connection (defaults work with bundled Docker Compose service)
DATABASE_URL=postgresql+asyncpg://tendril:tendril@postgres:5432/tendril

# ─────────────────────────────────────────────────────────────────
# OBJECT STORAGE (S3-compatible)
# ─────────────────────────────────────────────────────────────────

# MinIO or AWS S3 endpoint (defaults work with bundled Docker Compose MinIO)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tendril-photos

# ─────────────────────────────────────────────────────────────────
# MESSAGE BROKER (MQTT)
# ─────────────────────────────────────────────────────────────────

# EMQX or any MQTT broker (defaults work with bundled Docker Compose EMQX)
MQTT_BROKER_HOST=emqx
MQTT_BROKER_PORT=1883

# ─────────────────────────────────────────────────────────────────
# AI MODELS (optional — app works without them for manual mode)
# ─────────────────────────────────────────────────────────────────

# Local Ollama (install from ollama.com)
# Use 'http://host.docker.internal:11434' when running Docker on macOS/Windows
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral-nemo:12b

# Local Ollama vision model (for plant health checks)
OLLAMA_VISION_URL=http://host.docker.internal:11434
OLLAMA_VISION_MODEL=llava:7b

# Google Gemini API (fallback when Ollama unavailable)
# Get key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────
# BILLING & PAYMENTS (optional)
# ─────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────
# NOTIFICATIONS (optional — web push)
# ─────────────────────────────────────────────────────────────────

# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ─────────────────────────────────────────────────────────────────
# SOCIAL LOGIN (optional)
# ─────────────────────────────────────────────────────────────────

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
LOG_FORMAT=text

# ─────────────────────────────────────────────────────────────────
# INFRASTRUCTURE (advanced)
# ─────────────────────────────────────────────────────────────────

# Redis for rate limiting and caching (optional — falls back to in-memory)
REDIS_URL=redis://redis:6379/0

# Rate limiting
RATE_LIMIT_IP=6000
RATE_LIMIT_TENANT=6000
BRUTE_FORCE_MAX_ATTEMPTS=5

# Encryption for integration credentials
INTEGRATION_ENCRYPTION_KEY=QmYeqfro3qI8KO6j7SZ3Vfs9KOcddI7bbloJ087QhMs=
