# Tendril Kubernetes Secrets — EXAMPLE
#
# Copy this file to secrets.yaml and fill in real values:
#   cp secrets.yaml.example secrets.yaml
#
# NEVER commit secrets.yaml to git (it's in .gitignore).
# For production, use Sealed Secrets, HashiCorp Vault, or SOPS.

apiVersion: v1
kind: Secret
metadata:
  name: tendril-secrets
  namespace: tendril
type: Opaque
stringData:
  # ── Database ────────────────────────────────────────────
  DATABASE_URL: "postgresql+asyncpg://tendril:CHANGE_ME@postgresql.postgresql.svc.cluster.local:5432/tendril"

  # ── Auth ────────────────────────────────────────────────
  # Generate with: openssl rand -hex 32
  JWT_SECRET: "CHANGE_ME"

  # ── MQTT / EMQX ────────────────────────────────────────
  MQTT_BROKER_HOST: "emqx.emqx.svc.cluster.local"
  MQTT_BROKER_PORT: "8883"

  # ── Redis (optional — rate limiting & brute-force state) ─
  REDIS_URL: "redis://redis.redis.svc.cluster.local:6379/0"

  # ── AI ──────────────────────────────────────────────────
  GEMINI_API_KEY: ""
  GEMINI_MODEL: "gemini-2.5-flash"
  OLLAMA_BASE_URL: "http://ollama.ollama.svc.cluster.local:11434"
  OLLAMA_MODEL: "llama3.1:8b"

  # ── S3 / MinIO ─────────────────────────────────────────
  S3_ENDPOINT: "http://minio.minio.svc.cluster.local:9000"
  S3_ACCESS_KEY: "CHANGE_ME"
  S3_SECRET_KEY: "CHANGE_ME"
  S3_BUCKET: "tendril-photos"

  # ── Stripe ──────────────────────────────────────────────
  STRIPE_SECRET_KEY: ""
  STRIPE_WEBHOOK_SECRET: ""

  # ── OAuth ───────────────────────────────────────────────
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
  GITHUB_CLIENT_ID: ""
  GITHUB_CLIENT_SECRET: ""

  # ── Web Push (VAPID) ───────────────────────────────────
  VAPID_PRIVATE_KEY: ""
  VAPID_EMAIL: "mailto:admin@your-domain.com"

  # ── Email (Resend) ─────────────────────────────────────
  # Sign up at https://resend.com, verify your domain, get API key
  RESEND_API_KEY: ""
  EMAIL_FROM: "Tendril <noreply@your-domain.com>"

  # ── Integrations ───────────────────────────────────────
  # Generate with: python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
  INTEGRATION_ENCRYPTION_KEY: "CHANGE_ME"

  # ── App ─────────────────────────────────────────────────
  DOMAIN: "tendril.your-domain.com"
  CORS_ORIGINS: "https://tendril.your-domain.com"
  LOG_LEVEL: "INFO"
